{
  "sourceLanguage" : "en",
  "strings" : {
    "Access Code" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zugangscode"
          }
        }
      }
    },
    "Choose your Bambu Lab printer model so we can configure the best settings for your setup." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wähle dein Bambu Lab Druckermodell, damit wir die besten Einstellungen für dein Setup konfigurieren können."
          }
        }
      }
    },
    "Configure Your Slicer" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Slicer konfigurieren"
          }
        }
      }
    },
    "Connect" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verbinden"
          }
        }
      }
    },
    "Connect to your Bambu Lab printer to get started." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verbinde dich mit deinem Bambu Lab Drucker, um loszulegen."
          }
        }
      }
    },
    "Continue" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Weiter"
          }
        }
      }
    },
    "Credentials" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zugangsdaten"
          }
        }
      }
    },
    "Developer Mode disables cloud authentication so third-party apps can connect directly." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Developer Mode deaktiviert die Cloud-Authentifizierung, damit Drittanbieter-Apps direkt verbinden können."
          }
        }
      }
    },
    "Developer Mode on Bambu Wiki" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Developer Mode im Bambu Wiki"
          }
        }
      }
    },
    "Displayed under **LAN Only Mode** in your printer's network settings." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Angezeigt unter **LAN Only Mode** in den Netzwerkeinstellungen deines Druckers."
          }
        }
      }
    },
    "Done" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fertig"
          }
        }
      }
    },
    "e.g. 192.168.1.100" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "z. B. 192.168.1.100"
          }
        }
      }
    },
    "e.g. 0309DA561103403" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "z. B. 0309DA561103403"
          }
        }
      }
    },
    "e.g. 12345678" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "z. B. 12345678"
          }
        }
      }
    },
    "Enable LAN & Developer Mode" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LAN & Developer Mode aktivieren"
          }
        }
      }
    },
    "Enable Notifications" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mitteilungen aktivieren"
          }
        }
      }
    },
    "Enter Credentials" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zugangsdaten eingeben"
          }
        }
      }
    },
    "Enter the IP address and access code you found on your printer." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gib die IP-Adresse und den Zugangscode ein, die du auf deinem Drucker gefunden hast."
          }
        }
      }
    },
    "Enter your **Access Code** when prompted" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gib deinen **Zugangscode** ein, wenn du dazu aufgefordert wirst"
          }
        }
      }
    },
    "Find **LAN Only Mode** and turn it **ON**" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suche **LAN Only Mode** und schalte ihn **EIN**"
          }
        }
      }
    },
    "Find Your Credentials" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zugangsdaten finden"
          }
        }
      }
    },
    "Found on the **Device** tab in your printer's settings." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zu finden im Reiter **Device** in den Einstellungen deines Druckers."
          }
        }
      }
    },
    "Found under **Settings > WLAN** on your printer's touchscreen." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zu finden unter **Einstellungen > WLAN** auf dem Touchscreen deines Druckers."
          }
        }
      }
    },
    "Get notified when your prints and drying cycles finish — even when the app is in the background." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erhalte Benachrichtigungen, wenn deine Drucke und Trocknungszyklen fertig sind — auch wenn die App im Hintergrund ist."
          }
        }
      }
    },
    "Go to the **Device** page and select your printer" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Öffne die **Geräte**-Seite und wähle deinen Drucker"
          }
        }
      }
    },
    "Guide Me Through Setup" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Einrichtung Schritt für Schritt"
          }
        }
      }
    },
    "I Know What I'm Doing" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ich weiß, was ich tue"
          }
        }
      }
    },
    "IP Address" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "IP-Adresse"
          }
        }
      }
    },
    "LAN Mode and Developer Mode allow third-party apps like this one to communicate directly with your printer over your local network." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LAN Mode und Developer Mode ermöglichen Drittanbieter-Apps wie dieser, direkt über dein lokales Netzwerk mit deinem Drucker zu kommunizieren."
          }
        }
      }
    },
    "LAN Mode on Bambu Wiki" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LAN Mode im Bambu Wiki"
          }
        }
      }
    },
    "Look for the **lock icon** indicating LAN mode" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suche nach dem **Schloss-Symbol**, das den LAN Mode anzeigt"
          }
        }
      }
    },
    "Navigate to **WLAN** (or Network Settings)" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Navigiere zu **WLAN** (oder Netzwerkeinstellungen)"
          }
        }
      }
    },
    "Notifications" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mitteilungen"
          }
        }
      }
    },
    "On your printer's touchscreen, tap **Settings**" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tippe auf dem Touchscreen deines Druckers auf **Einstellungen**"
          }
        }
      }
    },
    "Open **Bambu Studio** on your computer" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Öffne **Bambu Studio** auf deinem Computer"
          }
        }
      }
    },
    "Printer Model" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Druckermodell"
          }
        }
      }
    },
    "Printer Setup" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Drucker-Einrichtung"
          }
        }
      }
    },
    "Read the notice, check the box and tap **Enable**" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lies den Hinweis, setze das Häkchen und tippe auf **Enable**"
          }
        }
      }
    },
    "Receive a notification when **filament drying** completes." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erhalte eine Benachrichtigung, wenn die **Filament-Trocknung** abgeschlossen ist."
          }
        }
      }
    },
    "Receive a notification when your **print finishes**." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erhalte eine Benachrichtigung, wenn dein **Druck fertig** ist."
          }
        }
      }
    },
    "Scroll down and find **Developer Mode**" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scrolle nach unten und suche **Developer Mode**"
          }
        }
      }
    },
    "Select a printer…" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Drucker auswählen …"
          }
        }
      }
    },
    "Select Your Printer" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Drucker auswählen"
          }
        }
      }
    },
    "Serial Number" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
